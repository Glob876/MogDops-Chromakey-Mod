{
	"schemaVersion": 1,
	"id": "mogdops-chromakey-mod",
	"version": "${version}",
	"name": "MogDop's Chromakey Mod",
	"icon": "assets/mogdops-chromakey-mod/icon.png",
	"description": "A Mod for functional chromakey effects!",
	"authors": [
		"MogDop"
	],
	"contact": {
		"homepage": "https://github.com/Glob876/MogDops-Chromakey-Mod",
		"sources": "https://github.com/Glob876/MogDops-Chromakey-Mod",
		"issues": "https://github.com/Glob876/MogDops-Chromakey-Mod/issues"
	},
	"license": "MIT",
	"environment": "*",
	"entrypoints": {
		"main": [
			"me.mogdop.ChromakeyMod"
		],
		"client": [
			"me.mogdop.client.ChromakeyModClient"
		]
	},
	"mixins": [
